{
    "name": "micro-panda",
    "displayName": "Micro Panda",
    "description": "Syntax highlighting for Micro Panda — a systems language that compiles to C, targeting MCU and hosted platforms",
    "version": "0.2.0",
    "publisher": "sang",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "micro-panda",
            "aliases": ["Micro Panda", "mpd"],
            "extensions": [".mpd"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "micro-panda",
            "scopeName": "source.mpd",
            "path": "./syntaxes/micro-panda.tmLanguage.json"
        }],
        "snippets": [{
            "language": "micro-panda",
            "path": "./snippets/micro-panda.json"
        }]
    }
}
