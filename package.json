{
    "name": "micro-panda",
    "displayName": "Micro Panda",
    "description": "Syntax highlighting and test runner for Micro Panda — a systems language that compiles to C, targeting MCU and hosted platforms",
    "version": "0.2.4",
    "publisher": "sang",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages",
        "Testing"
    ],
    "icon": "images/icon.png",
    "main": "./out/extension.js",
    "activationEvents": [
        "onLanguage:micro-panda",
        "workspaceContains:**/*_test.mpd"
    ],
    "contributes": {
        "languages": [{
            "id": "micro-panda",
            "aliases": ["Micro Panda", "mpd"],
            "extensions": [".mpd"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "micro-panda",
            "scopeName": "source.mpd",
            "path": "./syntaxes/micro-panda.tmLanguage.json"
        }],
        "snippets": [{
            "language": "micro-panda",
            "path": "./snippets/micro-panda.json"
        }],
        "problemMatchers": [{
            "name": "mpd",
            "owner": "micro-panda",
            "fileLocation": "absolute",
            "pattern": {
                "regexp": "^(.+):(\\d+):(\\d+): error: (.+)$",
                "file": 1,
                "line": 2,
                "column": 3,
                "message": 4
            }
        }],
        "taskDefinitions": [{
            "type": "mpd",
            "properties": {
                "target": {
                    "type": "string",
                    "description": "The mpd build target to run"
                }
            }
        }],
        "commands": [
            {
                "command": "microPanda.build",
                "title": "Build",
                "category": "Micro Panda"
            },
            {
                "command": "microPanda.gen",
                "title": "Generate C",
                "category": "Micro Panda"
            },
            {
                "command": "microPanda.run",
                "title": "Run Target",
                "category": "Micro Panda"
            }
        ],
        "configuration": {
            "title": "Micro Panda",
            "properties": {
                "microPanda.mpdPath": {
                    "type": "string",
                    "default": "mpd",
                    "description": "Path to the mpd compiler executable. Defaults to 'mpd' (must be on PATH)."
                }
            }
        }
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/node": "^18.0.0",
        "@types/vscode": "^1.74.0",
        "typescript": "^5.0.0"
    }
}
