{
    "name": "micro-panda",
    "displayName": "Micro Panda",
    "description": "Syntax highlighting for Micro Panda — a systems language that compiles to C, targeting MCU and hosted platforms",
    "version": "0.2.2",
    "publisher": "sang",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "micro-panda",
            "aliases": ["Micro Panda", "mpd"],
            "extensions": [".mpd"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "micro-panda",
            "scopeName": "source.mpd",
            "path": "./syntaxes/micro-panda.tmLanguage.json"
        }],
        "snippets": [{
            "language": "micro-panda",
            "path": "./snippets/micro-panda.json"
        }],
        "problemMatchers": [{
            "name": "mpd",
            "owner": "micro-panda",
            "fileLocation": "absolute",
            "pattern": {
                "regexp": "^(.+):(\\d+):(\\d+): error: (.+)$",
                "file": 1,
                "line": 2,
                "column": 3,
                "message": 4
            }
        }],
        "taskDefinitions": [{
            "type": "mpd",
            "properties": {
                "target": {
                    "type": "string",
                    "description": "The mpd build target to run"
                }
            }
        }]
    }
}
