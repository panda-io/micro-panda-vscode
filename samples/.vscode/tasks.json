{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "mpd: build",
            "type": "shell",
            "command": "mpd build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$mpd",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "mpd: gen",
            "type": "shell",
            "command": "mpd gen",
            "group": "build",
            "problemMatcher": "$mpd",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
