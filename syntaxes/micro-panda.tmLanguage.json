{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Micro Panda",
    "scopeName": "source.mpd",
    "fileTypes": ["mpd"],
    "patterns": [
        { "include": "#comment" },
        { "include": "#preprocessor" },
        { "include": "#annotation" },
        { "include": "#string" },
        { "include": "#char" },
        { "include": "#number" },
        { "include": "#function-decl" },
        { "include": "#class-decl" },
        { "include": "#enum-decl" },
        { "include": "#keyword-control" },
        { "include": "#keyword-declaration" },
        { "include": "#constant" },
        { "include": "#type-builtin" },
        { "include": "#type-name" },
        { "include": "#operator" }
    ],
    "repository": {

        "comment": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.mpd",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.mpd",
                    "begin": "/\\*",
                    "end": "\\*/",
                    "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.mpd" } },
                    "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.mpd" } }
                }
            ]
        },

        "preprocessor": {
            "patterns": [
                {
                    "comment": "#if / #elif <condition>",
                    "name": "meta.preprocessor.mpd",
                    "match": "^(#(?:if|elif))\\s+(.+)$",
                    "captures": {
                        "1": { "name": "keyword.control.preprocessor.mpd" },
                        "2": { "name": "meta.preprocessor.expression.mpd" }
                    }
                },
                {
                    "comment": "#else and #end",
                    "name": "keyword.control.preprocessor.mpd",
                    "match": "^#(?:else|end)\\b"
                }
            ]
        },

        "annotation": {
            "patterns": [
                {
                    "comment": "@name(\"string\") — annotation with argument",
                    "name": "meta.annotation.mpd",
                    "begin": "(@)([a-zA-Z_]\\w*)(\\()",
                    "end": "(\\))",
                    "beginCaptures": {
                        "1": { "name": "punctuation.definition.annotation.mpd" },
                        "2": { "name": "entity.other.attribute-name.mpd" },
                        "3": { "name": "punctuation.definition.annotation.mpd" }
                    },
                    "endCaptures": {
                        "1": { "name": "punctuation.definition.annotation.mpd" }
                    },
                    "patterns": [ { "include": "#string" } ]
                },
                {
                    "comment": "@name — bare annotation",
                    "match": "(@)([a-zA-Z_]\\w*)",
                    "captures": {
                        "1": { "name": "punctuation.definition.annotation.mpd" },
                        "2": { "name": "entity.other.attribute-name.mpd" }
                    }
                }
            ]
        },

        "string": {
            "name": "string.quoted.double.mpd",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.mpd",
                    "match": "\\\\[nrt\\\\\"'0]"
                }
            ]
        },

        "char": {
            "name": "string.quoted.single.mpd",
            "match": "'(?:[^'\\\\]|\\\\[nrt\\\\\"'0])'"
        },

        "number": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.mpd",
                    "match": "\\b0[xX][0-9a-fA-F_]+"
                },
                {
                    "name": "constant.numeric.binary.mpd",
                    "match": "\\b0[bB][01_]+"
                },
                {
                    "name": "constant.numeric.float.mpd",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:[eE][+-]?[0-9]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.mpd",
                    "match": "\\b[0-9][0-9_]*\\b"
                }
            ]
        },

        "function-decl": {
            "comment": "fun name<T>(...) — highlight name and optional generic param",
            "match": "\\b(fun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?:<([A-Z][a-zA-Z0-9_]*)>)?",
            "captures": {
                "1": { "name": "keyword.declaration.function.mpd" },
                "2": { "name": "entity.name.function.mpd" },
                "3": { "name": "entity.name.type.parameter.mpd" }
            }
        },

        "class-decl": {
            "match": "\\b(class)\\s+([A-Z][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.class.mpd" },
                "2": { "name": "entity.name.class.mpd" }
            }
        },

        "enum-decl": {
            "match": "\\b(enum)\\s+([A-Z][a-zA-Z0-9_]*)",
            "captures": {
                "1": { "name": "keyword.declaration.enum.mpd" },
                "2": { "name": "entity.name.type.enum.mpd" }
            }
        },

        "keyword-control": {
            "name": "keyword.control.mpd",
            "match": "\\b(if|else|for|while|return|break|continue|match|in|range)\\b"
        },

        "keyword-declaration": {
            "name": "keyword.declaration.mpd",
            "match": "\\b(val|var|const|import|as)\\b"
        },

        "constant": {
            "patterns": [
                {
                    "name": "constant.language.null.mpd",
                    "match": "\\bnull\\b"
                },
                {
                    "name": "constant.language.boolean.mpd",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "name": "variable.language.this.mpd",
                    "match": "\\bthis\\b"
                },
                {
                    "name": "keyword.operator.word.mpd",
                    "match": "\\bsizeof\\b"
                }
            ]
        },

        "type-builtin": {
            "name": "storage.type.mpd",
            "match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|float|fixed|bool|void)\\b"
        },

        "type-name": {
            "comment": "PascalCase identifiers treated as type/class names",
            "name": "entity.name.type.mpd",
            "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },

        "operator": {
            "patterns": [
                {
                    "name": "keyword.operator.assignment.mpd",
                    "match": ":=|\\+=|-=|\\*=|/=|%=|\\^=|&=|\\|=|<<=|>>=|="
                },
                {
                    "name": "keyword.operator.comparison.mpd",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.mpd",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.bitwise.mpd",
                    "match": "<<|>>|\\^|~"
                },
                {
                    "name": "keyword.operator.arithmetic.mpd",
                    "match": "\\+\\+|--|\\+|-|\\*|/|%"
                },
                {
                    "name": "keyword.operator.reference.mpd",
                    "match": "&"
                },
                {
                    "name": "punctuation.accessor.mpd",
                    "match": "::|\\."
                },
                {
                    "name": "punctuation.separator.colon.mpd",
                    "match": ":"
                },
                {
                    "name": "punctuation.separator.comma.mpd",
                    "match": ","
                }
            ]
        }
    }
}
